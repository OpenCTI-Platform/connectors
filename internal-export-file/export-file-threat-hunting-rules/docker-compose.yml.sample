services:
  connector-export-file-threat-hunting-rules:
    image: opencti/connector-export-file-threat-hunting-rules:<PYCTI_VERSION>
    environment:
      - OPENCTI_URL=http://opencti:8080
      - OPENCTI_TOKEN=ChangeMe
      - CONNECTOR_ID=ChangeMe
      - CONNECTOR_NAME=ExportFileThreatHuntingRules
      - CONNECTOR_SCOPE=application/zip
      - CONNECTOR_LOG_LEVEL=info
    platform: linux/amd64
    restart: always
    depends_on:
      opencti:
        condition: service_healthy