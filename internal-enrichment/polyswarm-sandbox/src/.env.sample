OPENCTI_URL=http://localhost:8080
OPENCTI_TOKEN=ChangeMe

#CONNECTOR_ID=ChangeMe
#CONNECTOR_NAME=PolySwarm Sandbox
#CONNECTOR_SCOPE=Artifact
#CONNECTOR_AUTO=false
#CONNECTOR_LOG_LEVEL=error
#POLYSWARM_MAX_TLP=TLP:AMBER
#POLYSWARM_REPLACE_WITH_LOWER_SCORE=true
#CONNECTOR_ENRICHMENT_RESOLUTION=AUTHORIZED_AUTHORITIES

POLYSWARM_API_KEY=ChangeMe
#POLYSWARM_API_URL=https://api.polyswarm.network
#POLYSWARM_COMMUNITY=default
#POLYSWARM_TIMEOUT=300

# Sandbox settings
#POLYSWARM_SANDBOX_ENABLED=true
#POLYSWARM_SANDBOX_PROVIDER=cape
#POLYSWARM_SANDBOX_VM_CAPE=win-10-build-19041
#POLYSWARM_SANDBOX_VM_TRIAGE=windows11-21h2-x64
#POLYSWARM_SANDBOX_NETWORK_ENABLED=true
#POLYSWARM_SANDBOX_TIMEOUT=600

# Polling
#POLYSWARM_POLL_INTERVAL=30
#POLYSWARM_POLL_TIMEOUT=900

# Reports
#POLYSWARM_JSON_REPORT_ENABLED=true
#POLYSWARM_PDF_REPORT_ENABLED=true
#POLYSWARM_LLM_REPORT_ENABLED=false
#POLYSWARM_LLM_REPORT_TIMEOUT=120

# STIX creation
#POLYSWARM_MIN_POLYSCORE=50
#POLYSWARM_CREATE_INDICATORS=true
#POLYSWARM_CREATE_OBSERVABLES=true

# File handling
#POLYSWARM_MAX_FILE_SIZE=33554432
#POLYSWARM_DOWNLOAD_ARTIFACTS=true

# polykg (optional — malware profile enrichment)
#POLYKG_API_URL=
