# Generic parameters (connection with OpenCTI)

# Required
OPENCTI_URL=http://localhost
# Required
OPENCTI_TOKEN=CHANGEME


# Common parameters for connectors of type INTERNAL_ENRICHMENT

# Optional (default: generated UUIDv4)
CONNECTOR_ID=CHANGEME
# Optional (default: 'YARA')
CONNECTOR_NAME=YARA
# Optional (default: 'Artifact')
CONNECTOR_SCOPE=Artifact
# Optional (default: 'error')
CONNECTOR_LOG_LEVEL=error
# Optional (default: false)
CONNECTOR_AUTO=false
