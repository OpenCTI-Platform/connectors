# OpenCTI Platform Configuration
OPENCTI_URL=http://localhost:8080
OPENCTI_ADMIN_TOKEN=ChangeMe

# WhoisFreaks Connector Configuration
CONNECTOR_KEY=ChangeMe_Generate_UUIDv4
CONNECTOR_NAME=WhoisFreaks
CONNECTOR_TYPE=INTERNAL_ENRICHMENT
CONNECTOR_SCOPE=Domain-Name,IPv4-Addr,IPv6-Addr
CONNECTOR_AUTO=false
CONNECTOR_CONFIDENCE_LEVEL=100
CONNECTOR_LOG_LEVEL=INFO

# WhoisFreaks API Credentials
WHOISFREAKS_API_KEY=YOUR_WHOISFREAKS_API_KEY_HERE