# Required secrets/identifiers used by docker-compose.yml
OPENCTI_ADMIN_TOKEN=
CONNECTOR_SPLUNK_SEARCH_ID=
SPLUNK_TOKEN=

# Optional values (docker-compose.yml also defines defaults)
OPENCTI_URL=http://opencti:8080
OPENCTI_SSL_VERIFY=true
CONNECTOR_TYPE=INTERNAL_ENRICHMENT
CONNECTOR_NAME=SplunkSearch
CONNECTOR_SCOPE=Indicator
CONNECTOR_LOG_LEVEL=info
CONNECTOR_AUTO=false
CONNECTOR_API_HOST_PORT=7070
CONNECTOR_LISTEN_PROTOCOL_API_URI=http://127.0.0.1:7070
SPLUNK_HOST=splunk.example.com
SPLUNK_PORT=8089
SPLUNK_APP=search
SPLUNK_SCHEME=https
SPLUNK_VERIFY_SSL=true
SPLUNK_SEARCH_EARLIEST=-30d@d
SPLUNK_SEARCH_LATEST=now
SPLUNK_SEARCH_TIMEOUT=60
SPLUNK_WAIT_SECONDS=2
SPLUNK_MAX_RESULTS=1000
SPLUNK_SIGHTING_TLP=TLP:AMBER
SPLUNK_OBSERVABLE_TLP=TLP:AMBER
