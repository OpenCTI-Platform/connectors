# Source this file before running the connector locally:
#   cp .env.test.sample .env.test
#   # edit values
#   source .env.test
#   python3 main.py

# --- OpenCTI ---
export OPENCTI_URL="http://localhost:8080"
export OPENCTI_TOKEN="REPLACE_WITH_ADMIN_TOKEN_FROM_OPENCTI_DOTENV"

# --- Connector ---
export CONNECTOR_ID="REPLACE_WITH_UUIDV4"     # generate with: uuidgen | tr A-Z a-z
export CONNECTOR_TYPE="INTERNAL_ENRICHMENT"
export CONNECTOR_NAME="Stairwell (manual test)"
export CONNECTOR_SCOPE="StixFile,Domain-Name,IPv4-Addr,IPv6-Addr,Autonomous-System"
export CONNECTOR_AUTO="false"                 # true = auto-enrich every new in-scope observable
export CONNECTOR_LOG_LEVEL="info"

# --- Stairwell ---
export STAIRWELL_API_TOKEN="REPLACE_WITH_STAIRWELL_API_TOKEN"
export STAIRWELL_API_BASE_URL="https://app.stairwell.com"
export STAIRWELL_ORGANIZATION_ID=""           # optional, for rate-limit boost
export STAIRWELL_USER_ID=""                   # optional, for rate-limit boost

# --- Enrichment behavior ---
export STAIRWELL_DEFAULT_TLP="amber"          # clear | green | amber | amber+strict | red
export STAIRWELL_MAX_TLP_LEVEL="red"          # max TLP the connector will enrich (clear..red)
export STAIRWELL_VARIANT_LIMIT=25             # max variant SCOs per file (0 disables)
export STAIRWELL_RESOLUTIONS_LIMIT=50         # max DNS resolution rows per domain (0 disables)
export STAIRWELL_SIGHTINGS_LIMIT=100          # max unique assets per file (0 disables sightings)
