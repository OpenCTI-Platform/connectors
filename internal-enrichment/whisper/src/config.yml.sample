opencti:
  url: "http://opencti:8080"
  token: "ChangeMe"

connector:
  id: "ChangeMe-uuid4"
  type: "INTERNAL_ENRICHMENT"
  name: "Whisper"
  scope: "IPv4-Addr,IPv6-Addr,Domain-Name,Autonomous-System"
  auto: false
  log_level: "info"

whisper:
  api_url: "https://graph.whisper.security"
  api_key: "ChangeMe"
  max_tlp: "TLP:AMBER"
