opencti:
  url: 'http://localhost'
  token: 'ChangeMe'

connector:
  type: 'EXTERNAL_IMPORT'
  id: 'ChangeMe'
  name: 'Google SecOps'   # optional (default: 'Google SecOps')
  scope: 'google-secops-siem-incidents'
  log_level: 'error'      # optional (default: 'error')
  duration_period: 'PT1H' # optional (default: 'PT1H')

google_secops_siem_incidents:
  chronicle_base_url: 'https://chronicle.googleapis.com'  # optional (default: 'https://chronicle.googleapis.com')
  chronicle_project_id: 'ChangeMe'
  chronicle_project_region: 'us'                          # e.g. 'us', 'eu', 'asia'
  chronicle_project_instance: 'ChangeMe'                  # Chronicle instance UUID
  chronicle_private_key: 'ChangeMe'                       # Service account private key (PEM)
  chronicle_private_key_id: 'ChangeMe'
  chronicle_client_email: 'ChangeMe'
  chronicle_client_id: 'ChangeMe'
  chronicle_auth_uri: 'https://accounts.google.com/o/oauth2/auth'    # optional
  chronicle_token_uri: 'https://oauth2.googleapis.com/token'         # optional
  chronicle_auth_provider_cert: 'https://www.googleapis.com/oauth2/v1/certs'  # optional
  chronicle_client_cert_url: 'ChangeMe'
  tlp_level: 'amber'    # optional: clear/white/green/amber/amber+strict/red (default: 'amber')
  first_start_time: 'P1D' # optional, ISO-8601 duration to look back on first run (default: 'P1D')
