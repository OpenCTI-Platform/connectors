{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.filigran.io/connectors/vulncheck_config.schema.json",
  "type": "object",
  "properties": {
    "OPENCTI_URL": {
      "description": "The base URL of the OpenCTI instance.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string"
    },
    "OPENCTI_TOKEN": {
      "description": "The API token to connect to OpenCTI.",
      "type": "string"
    },
    "CONNECTOR_NAME": {
      "default": "VulnCheck Connector",
      "description": "Display name for this connector instance in the OpenCTI platform.",
      "type": "string"
    },
    "CONNECTOR_SCOPE": {
      "default": [
        "vulnerability",
        "malware",
        "threat-actor",
        "infrastructure",
        "location",
        "ip-addr",
        "indicator",
        "external-reference",
        "software",
        "report"
      ],
      "description": "Entity types this connector will handle.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "CONNECTOR_LOG_LEVEL": {
      "default": "error",
      "description": "The minimum level of logs to display.",
      "enum": [
        "debug",
        "info",
        "warn",
        "warning",
        "error"
      ],
      "type": "string"
    },
    "CONNECTOR_TYPE": {
      "const": "EXTERNAL_IMPORT",
      "default": "EXTERNAL_IMPORT",
      "type": "string"
    },
    "CONNECTOR_DURATION_PERIOD": {
      "default": "PT1H",
      "description": "Time interval between consecutive data imports.",
      "format": "duration",
      "type": "string"
    },
    "CONNECTOR_VULNCHECK_API_KEY": {
      "description": "Use VULNCHECK_API_KEY instead.",
      "format": "password",
      "type": "string",
      "writeOnly": true,
      "deprecated": true
    },
    "CONNECTOR_VULNCHECK_API_BASE_URL": {
      "default": "https://api.vulncheck.com/v3",
      "description": "Use VULNCHECK_API_BASE_URL instead.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string",
      "deprecated": true
    },
    "CONNECTOR_VULNCHECK_DATA_SOURCES": {
      "default": "vulncheck-kev,nist-nvd2",
      "description": "Use VULNCHECK_DATA_SOURCES instead.",
      "type": "string",
      "deprecated": true
    },
    "VULNCHECK_API_KEY": {
      "description": "API key for authenticating with the VulnCheck API.",
      "format": "password",
      "type": "string",
      "writeOnly": true
    },
    "VULNCHECK_API_BASE_URL": {
      "default": "https://api.vulncheck.com/v3",
      "description": "Base URL for the VulnCheck API.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string"
    },
    "VULNCHECK_DATA_SOURCES": {
      "default": "vulncheck-kev,nist-nvd2",
      "description": "Comma-separated list of data sources to ingest. Available: botnets, epss, exploits, initial-access, ipintel, nist-nvd2, ransomware, snort, suricata, threat-actors, vulncheck-kev, vulncheck-nvd2.",
      "type": "string"
    }
  },
  "required": [
    "OPENCTI_URL",
    "OPENCTI_TOKEN",
    "VULNCHECK_API_KEY"
  ],
  "additionalProperties": true
}