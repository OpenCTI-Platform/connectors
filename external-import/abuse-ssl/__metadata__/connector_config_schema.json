{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.filigran.io/connectors/abuse-ssl_config.schema.json",
  "type": "object",
  "properties": {
    "OPENCTI_URL": {
      "description": "The base URL of the OpenCTI instance.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string"
    },
    "OPENCTI_TOKEN": {
      "description": "The API token to connect to OpenCTI.",
      "type": "string"
    },
    "CONNECTOR_NAME": {
      "default": "Abuse.ch SSL Blacklist",
      "description": "The name of the connector.",
      "type": "string"
    },
    "CONNECTOR_SCOPE": {
      "default": [
        "abuse-ssl"
      ],
      "description": "The scope of the connector.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "CONNECTOR_LOG_LEVEL": {
      "default": "info",
      "description": "The minimum level of logs to display.",
      "enum": [
        "debug",
        "info",
        "warn",
        "warning",
        "error"
      ],
      "type": "string"
    },
    "CONNECTOR_TYPE": {
      "const": "EXTERNAL_IMPORT",
      "default": "EXTERNAL_IMPORT",
      "type": "string"
    },
    "ABUSESSL_URL": {
      "default": "https://sslbl.abuse.ch/blacklist/sslipblacklist.csv",
      "description": "The URL of the Abuse.ch SSL blacklist CSV file containing botnet C&C IP addresses.",
      "format": "uri",
      "type": "string"
    },
    "ABUSESSL_INTERVAL": {
      "default": 360,
      "description": "The interval (in minutes) between two connector runs.",
      "type": "integer"
    }
  },
  "required": [
    "OPENCTI_URL",
    "OPENCTI_TOKEN",
    "ABUSESSL_URL",
    "ABUSESSL_INTERVAL"
  ],
  "additionalProperties": true
}

