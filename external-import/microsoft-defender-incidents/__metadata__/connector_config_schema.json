{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.filigran.io/connectors/microsoft_defender_incidents_config.schema.json",
  "type": "object",
  "properties": {
    "OPENCTI_URL": {
      "description": "The base URL of the OpenCTI instance.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string"
    },
    "OPENCTI_TOKEN": {
      "description": "The API token to connect to OpenCTI.",
      "type": "string"
    },
    "CONNECTOR_NAME": {
      "default": "Microsoft Defender Incidents",
      "description": "The name of the connector.",
      "type": "string"
    },
    "CONNECTOR_SCOPE": {
      "default": [
        "defender"
      ],
      "description": "The scope of the connector.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "CONNECTOR_LOG_LEVEL": {
      "default": "error",
      "description": "The minimum level of logs to display.",
      "enum": [
        "debug",
        "info",
        "warn",
        "warning",
        "error"
      ],
      "type": "string"
    },
    "CONNECTOR_TYPE": {
      "const": "EXTERNAL_IMPORT",
      "default": "EXTERNAL_IMPORT",
      "type": "string"
    },
    "CONNECTOR_DURATION_PERIOD": {
      "default": "PT5M",
      "description": "The period of time to await between two runs of the connector.",
      "format": "duration",
      "type": "string"
    },
    "MICROSOFT_DEFENDER_INCIDENTS_TENANT_ID": {
      "description": "The Azure Tenant ID.",
      "type": "string"
    },
    "MICROSOFT_DEFENDER_INCIDENTS_CLIENT_ID": {
      "description": "The Azure App Client ID.",
      "type": "string"
    },
    "MICROSOFT_DEFENDER_INCIDENTS_CLIENT_SECRET": {
      "description": "The Azure App Client Secret.",
      "format": "password",
      "type": "string",
      "writeOnly": true
    },
    "MICROSOFT_DEFENDER_INCIDENTS_API_BASE_URL": {
      "default": "https://graph.microsoft.com/v1.0",
      "description": "The base URL for the Microsoft Graph API.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string"
    },
    "MICROSOFT_DEFENDER_INCIDENTS_INCIDENT_PATH": {
      "default": "/security/incidents",
      "description": "The API path for fetching security incidents.",
      "type": "string"
    },
    "MICROSOFT_DEFENDER_INCIDENTS_IMPORT_START_DATE": {
      "default": "2025-01-01T00:00:00Z",
      "description": "The date from which incidents will be imported. Timestamp in ISO 8601 format, UTC.",
      "format": "date-time",
      "type": "string"
    }
  },
  "required": [
    "OPENCTI_URL",
    "OPENCTI_TOKEN",
    "MICROSOFT_DEFENDER_INCIDENTS_TENANT_ID",
    "MICROSOFT_DEFENDER_INCIDENTS_CLIENT_ID",
    "MICROSOFT_DEFENDER_INCIDENTS_CLIENT_SECRET"
  ],
  "additionalProperties": true
}
