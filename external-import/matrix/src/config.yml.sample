opencti:
  url: 'http://localhost'
  token: 'ChangeMe'

connector:
  id: 'ChangeMe'
  type: 'EXTERNAL_IMPORT'
  name: 'Matrix'
  scope: 'matrix'
  log_level: 'info'

matrix:
  server: 'https://matrix.example.org'
  user_id: '@octi-bot:matrix.example.org'
  password: 'ChangeMe'
  device_name: 'octi_bot'
  # TLP marking applied to created entities. Supported values:
  # - CLEAR             — modern OpenCTI marking, ``x_opencti_definition='TLP:CLEAR'``
  # - WHITE             — legacy ``stix2.TLP_WHITE`` constant (distinct marking-definition
  #                       object from CLEAR; kept for backwards compatibility)
  # - GREEN, AMBER, RED — built-in stix2 markings
  # - AMBER_STRICT      — also accepted as AMBER+STRICT / AMBER STRICT / AMBER-STRICT
  # Case-insensitive.
  tlp: 'AMBER'
  debug: false
  # Optional: where to keep the matrix-nio store (sync token + device keys).
  # Defaults to ``./store`` (relative to ``main.py``).
  # store_path: '/opt/opencti-connector-matrix/store'
