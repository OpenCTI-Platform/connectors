opencti:
  url: 'http://localhost'
  token: 'ChangeMe'

# Detached opencti-ng mode (optional): set both keys below to ingest directly
# into opencti-ng over a JWT (no OpenCTI worker/queue). The write tenant and
# connector id are read from the JWT; run state lives server-side.
# Generate the JWT in the opencti-ng repo:
#   OPENCTI_ENCRYPTION_KEY=<key> cargo run --bin connector_jwt -- \
#     --tenant <tenant-uuid> --name SEKOIA.IO
# (env equivalents: OPENCTI_NG_URL / OPENCTI_NG_JWT)
# opencti_ng_url: 'http://localhost:4100'
# opencti_ng_jwt: 'ChangeMe'

connector:
  type: 'EXTERNAL_IMPORT'
  id: 'ChangeMe'

sekoia:
  api_key: 'ChangeMe'
