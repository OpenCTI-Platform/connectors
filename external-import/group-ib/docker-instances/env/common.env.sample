# === OpenCTI Server ===
# http://opencti:8080 - for docker deployment, http://localhost:8080 - for manual deployment
OPENCTI_URL=http://opencti:8080
# Use one as provided by the OpenCTI platform
OPENCTI_TOKEN=

# === OpenCTI Connector ===
# Generate one with uuidgen (https://www.uuidgenerator.net/version4)
CONNECTOR_TYPE=EXTERNAL_IMPORT
CONNECTOR_SCOPE=stix2,report,threat-actor,intrusion-set,malware,attack-pattern,vulnerability,indicator,location,identity,incident,note,relationship,ipv4-addr,ipv6-addr,domain,url,StixFile,email-addr,user-account,payment-card,bank-account
# One of the following: debug, info, warning, error
CONNECTOR_LOG_LEVEL="info"
# Specifies the time interval in ISO 8601 format (Duration):
# Format: P[n]Y[n]M[n]DT[n]H[n]M[n]S
# - P: indicates the beginning of the period (Period).
# - T: separates date and time, used before time components.
# - n: a number representing a quantity (e.g. 3 for 3 minutes).
#
# Examples:
# - PT3M: an interval of 3 minutes.
# - PT5S: an interval of 5 seconds.
# - P1DT2H: an interval of 1 day and 2 hours.
CONNECTOR_DURATION_PERIOD=PT4H
CONNECTOR_UPDATE_EXISTING_DATA=true

# === RabbitMQ Server used for integration manual run ===
CONNECTOR_MQ_HOST=localhost
CONNECTOR_MQ_PORT=5672
CONNECTOR_MQ_VHOST=/
CONNECTOR_MQ_USE_SSL=false
CONNECTOR_MQ_USER=guest
CONNECTOR_MQ_PASS=guest

# === Threat Intelligence API Server ===
# Connector specific parameters. All params are mandatory.
TI_API__URL=https://tap.group-ib.com/api/v2/
TI_API__USERNAME=
TI_API__TOKEN=

# === Threat Intelligence API Proxy ===
# Proxy specifc parameters. You can leave them blank.
TI_API__PROXY__IP=
TI_API__PROXY__PORT=
TI_API__PROXY__PROTOCOL=
TI_API__PROXY__USERNAME=
TI_API__PROXY__PASSWORD=

# Threat Intelligence Collections settings
TI_API__EXTRA_SETTINGS__IGNORE_NON_INDICATOR_THREAT_REPORTS=false
TI_API__EXTRA_SETTINGS__IGNORE_NON_INDICATOR_THREATS=false
TI_API__EXTRA_SETTINGS__IGNORE_NON_MALWARE_DDOS=true
TI_API__EXTRA_SETTINGS__INTRUSION_SET_INSTEAD_OF_THREAT_ACTOR=false
TI_API__EXTRA_SETTINGS__TIME_OUTPUT_FORMAT='%Y-%m-%d %H:%M:%S'
TI_API__EXTRA_SETTINGS__ENABLE_STATEMENT_MARKING=false
# When true, the connector omits x_opencti_labels from STIX bundles so the OpenCTI
# worker's update path does not overwrite labels that were added manually by
# analysts. Trade-off: connector-supplied labels also stop being (re)applied.
TI_API__EXTRA_SETTINGS__PRESERVE_MANUAL_LABELS=false

# Development only: write logs to rotating files (connector.log inside LOG_FILE_DIR)
# Not intended for production use. Ensure the directory is mounted as a volume in docker-compose.yml
TI_API__EXTRA_SETTINGS__ENABLE_FILE_LOGGING=false
TI_API__EXTRA_SETTINGS__LOG_FILE_DIR=/opt/connector/logs
TI_API__EXTRA_SETTINGS__LOG_FILE_MAX_BYTES=10485760
TI_API__EXTRA_SETTINGS__LOG_FILE_BACKUP_COUNT=5