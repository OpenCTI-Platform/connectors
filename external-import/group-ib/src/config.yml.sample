opencti:
  # http://opencti:8080 - for docker deployment, http://localhost:8080 - for manual deployment
  url: "http://opencti:8080"
  # Use one as provided by the OpenCTI platform
  token: ""

connector:
  # Generate one with uuidgen (https://www.uuidgenerator.net/version4)
  id: ""
  type: "EXTERNAL_IMPORT"
  name: "Group-IB Connector"
  scope: "stix2,report,threat-actor,intrusion-set,malware,attack-pattern,vulnerability,indicator,location,identity,incident,note,relationship,ipv4-addr,ipv6-addr,domain,url,StixFile,email-addr,user-account,payment-card,bank-account"
  docker_container_name: "gib_connector"
  # One of the following: debug, info, warning, error
  log_level: "info"
  # Specifies the time interval in ISO 8601 format (Duration):
  # Format: P[n]Y[n]M[n]DT[n]H[n]M[n]S
  # - P: indicates the beginning of the period (Period).
  # - T: separates date and time, used before time components.
  # - n: a number representing a quantity (e.g. 3 for 3 minutes).
  #
  # Examples:
  # - PT3M: an interval of 3 minutes.
  # - PT5S: an interval of 5 seconds.
  # - P1DT2H: an interval of 1 day and 2 hours.
  duration_period: "PT4H"
  update_existing_data: true
  # === RabbitMQ Server used for integration manual run ===
  mq_host: localhost
  mq_port: 5672
  mq_vhost: "/"
  mq_use_ssl: false
  mq_user: "guest"
  mq_pass: "guest"

# === Threat Intelligence API Server ===
# TI URL and credentials are required. Proxy fields may be left empty.
ti_api:
    url: "https://tap.group-ib.com/api/v2/"
    username: ""
    token: ""
    # === Threat Intelligence API Proxy ===
    # Proxy specific parameters. You can leave them blank.
    proxy:
      ip:
      port:
      protocol:
      username:
      password:

    # === Threat Intelligence Collections settings
    # Per-collection keys: see README parameter reference and .env.sample.

    extra_settings:
      ignore_non_indicator_threat_reports: false
      ignore_non_indicator_threats: false
      ignore_non_malware_ddos: true
      intrusion_set_instead_of_threat_actor: false
      time_output_format: '%Y-%m-%d %H:%M:%S'
      enable_statement_marking: false
      # When true, the connector omits x_opencti_labels from STIX bundles so the
      # OpenCTI worker's update path does not overwrite labels that were added
      # manually by analysts. Trade-off: connector-supplied labels also stop being
      # (re)applied to existing entities. Default false preserves prior behavior.
      preserve_manual_labels: false
      # Development only: write logs to rotating files (connector.log inside log_file_dir)
      # Not intended for production use. Ensure the directory is mounted as a volume in docker-compose.yml
      enable_file_logging: false
      log_file_dir: /opt/connector/logs
      log_file_max_bytes: 10485760
      log_file_backup_count: 5

    collections:

      apt/threat:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 1460
        use_hunting_rules: false
        # Per-collection settings (defaults: labels=true, others=false)
        store_report_labels_in_note: false
        add_threat_actor_label_to_observables: true
        include_threat_actor_labels: true
        include_nation_state_label: true
        include_context_label: true
        description_in_external_references: false
        # Promote report victimology into searchable SDOs: sectors -> Identity (Sector),
        # targetedCompany / targetedPartnersAndClients -> Identity (Organization),
        # regions -> Location (Region); linked "<actor> targets <entity>" when present.
        targeted_entities_as_sdo: true
        # Add expertise labels (bare values) from the report "expertise" field.
        include_expertise_labels: true

      apt/threat_actor:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 1460
        use_hunting_rules: false
        include_nation_state_label: true
        description_in_external_references: false

      attacks/ddos:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 10
        use_hunting_rules: false
        # CnC (attacker) domain/url/ip become Indicators; target stays a plain observable.
        cnc_as_indicator: true
        # Create an Incident SDO per DDoS attack (linked to observables/malware/actor).
        create_incident: true

      attacks/deface:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 10
        # Create an Incident SDO per defacement (linked to observables/actor/location).
        create_incident: true

      attacks/phishing_group:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 5
        use_hunting_rules: false
        # Impersonated brand -> Identity (Organization) linked to the phishing observables.
        brand_as_identity: true
        # Add brand labels (bare brand names) to all emitted entities of the event.
        include_brand_labels: true

      attacks/phishing_kit:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 30
        use_hunting_rules: false
        # targetBrand values -> Identity (Organization) linked to the kit observables.
        brand_as_identity: true
        include_brand_labels: true

      compromised/access:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 1460
        # Raw data block in note: max chars for preview; if full_data true, no truncation
        data_preview_max_len: 2000
        full_data: false
        description_in_external_references: false
        # CnC (marketplace) domain/url/ip become Indicators (valid_from = compromise date, + TTL).
        cnc_as_indicator: true
        # Emit target.host/domain/ip as plain observables so customers can search their assets.
        target_observables: true

      compromised/account_group:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 1460
        # Include compromised account group options (connector behavior)
        include_passwords: false
        include_malware_labels: true
        include_malware_threat_actor_labels: true
        # If true, add labels from API field "source_type" (e.g. leak type) to observables/entities as bare values
        include_source_type_labels: true
        description_in_external_references: false
        # API request parameters for this collection (1 or 0)
        unique: 0
        combolist: 0
        probable_corporate_access: 0

      compromised/spd:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 90
        description_in_external_references: false

      compromised/bank_card_group:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 730
        description_in_external_references: false

      compromised/discord:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 30
        use_hunting_rules: false
        # When true, the message body is omitted from the Note (only metadata: channel + author + ts).
        # Use for privacy/PII compliance — chat messages often contain personal data.
        redact_message_text: false
        # When true, message translation (if present) is appended to the Note.
        include_translation_in_note: true
        # Note body preview limits (used when `redact_message_text=false`)
        full_data: false
        data_preview_max_len: 4000

      compromised/masked_card:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 90
        description_in_external_references: false
        include_malware_labels: true
        include_threat_actor_labels: true
        include_source_type_labels: true

      compromised/messenger:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 30
        use_hunting_rules: false
        redact_message_text: false
        include_translation_in_note: true
        full_data: false
        data_preview_max_len: 4000

      darkweb/forums:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 90
        use_hunting_rules: false

      hi/open_threats:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 30
        use_hunting_rules: false
        description_in_external_references: false
        # Text/original in Note: max chars for preview; if full_data true, no truncation
        data_preview_max_len: 2000
        full_data: false
        # Include text and original fields in Note (can be disabled for large reports)
        include_text_in_note: true
        include_original_in_note: false
        # Report IoCs (domains/urls/ips/file hashes) become Indicators (valid_from =
        # report date, + TTL).
        observables_as_indicators: true

      hi/threat:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 1460
        use_hunting_rules: false
        store_report_labels_in_note: false
        add_threat_actor_label_to_observables: true
        include_threat_actor_labels: true
        include_cybercriminal_label: true
        include_context_label: true
        description_in_external_references: false
        # Same victimology promotion as apt/threat (sectors/companies/partners/regions).
        targeted_entities_as_sdo: true
        include_expertise_labels: true

      hi/threat_actor:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 1460
        use_hunting_rules: false
        include_cybercriminal_label: true
        description_in_external_references: false

      ioc/primary:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 90

      malware/cnc:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 90
        include_malware_labels: true
        include_threat_actor_labels: true
        # Every CnC value (domain, url, ipv4, ipv6, file hashes) becomes an Indicator.
        # Set to false to revert to a single primary Indicator per event.
        all_observables_as_indicators: true

      malware/config:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 90
        use_hunting_rules: false
        description_in_external_references: false
        include_malware_labels: true

      malware/malware:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 1460
        description_in_external_references: false

      malware/signature:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 30

      malware/yara:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 30

      osi/git_repository:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 30
        use_hunting_rules: false
        description_in_external_references: false
        # Commit author emails -> Email-Addr observables linked to the leak Incident.
        author_email_observables: true

      osi/public_leak:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 15
        use_hunting_rules: false
        # Data block in note: max chars for preview; if full_data true, no truncation
        data_preview_max_len: 2000
        full_data: false
        description_in_external_references: false

      osi/vulnerability:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 90
        use_hunting_rules: false

      suspicious_ip/open_proxy:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 5
        use_hunting_rules: false

      suspicious_ip/scanner:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 5
        use_hunting_rules: false

      suspicious_ip/socks_proxy:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 5
        use_hunting_rules: false

      suspicious_ip/tor_node:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 5
        use_hunting_rules: false

      suspicious_ip/vpn:
        default_date: ''
        enable: false
        local_custom_tag: null
        ttl: 5
        use_hunting_rules: false
