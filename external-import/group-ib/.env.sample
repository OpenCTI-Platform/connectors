# === OpenCTI Server ===
# http://opencti:8080 - for docker deployment, http://localhost:8080 - for manual deployment
OPENCTI_URL=http://localhost
# Use one as provided by the OpenCTI platform
OPENCTI_TOKEN=ChangeMe

# === OpenCTI Connector ===
# Docker container name
CONNECTOR_DOCKER_CONTAINER_NAME=gib_connector
# Generate one with uuidgen (https://www.uuidgenerator.net/version4)
CONNECTOR_ID=
CONNECTOR_TYPE=EXTERNAL_IMPORT
CONNECTOR_NAME=Group-IB Connector
CONNECTOR_SCOPE=stix2,report,threat-actor,intrusion-set,malware,attack-pattern,vulnerability,indicator,location,identity,incident,note,relationship,ipv4-addr,ipv6-addr,domain,url,StixFile,email-addr,user-account,payment-card,bank-account
# One of the following: debug, info, warning, error
CONNECTOR_LOG_LEVEL="info"
# Specifies the time interval in ISO 8601 format (Duration):
# Format: P[n]Y[n]M[n]DT[n]H[n]M[n]S
# - P: indicates the beginning of the period (Period).
# - T: separates date and time, used before time components.
# - n: a number representing a quantity (e.g. 3 for 3 minutes).
#
# Examples:
# - PT3M: an interval of 3 minutes.
# - PT5S: an interval of 5 seconds.
# - P1DT2H: an interval of 1 day and 2 hours.
CONNECTOR_DURATION_PERIOD=PT4H
CONNECTOR_UPDATE_EXISTING_DATA=true

# === RabbitMQ Server used for integration manual run ===
CONNECTOR_MQ_HOST=localhost
CONNECTOR_MQ_PORT=5672
CONNECTOR_MQ_VHOST=/
CONNECTOR_MQ_USE_SSL=false
CONNECTOR_MQ_USER=guest
CONNECTOR_MQ_PASS=guest

# === Threat Intelligence API Server ===
# Connector specific parameters. All params are mandatory.
TI_API__URL=https://tap.group-ib.com/api/v2/
TI_API__USERNAME=
TI_API__TOKEN=

# === Threat Intelligence API Proxy ===
# Proxy specifc parameters. You can leave them blank.
TI_API__PROXY__IP=
TI_API__PROXY__PORT=
TI_API__PROXY__PROTOCOL=
TI_API__PROXY__USERNAME=
TI_API__PROXY__PASSWORD=

# Threat Intelligence Collections settings
TI_API__EXTRA_SETTINGS__IGNORE_NON_INDICATOR_THREAT_REPORTS=false
TI_API__EXTRA_SETTINGS__IGNORE_NON_INDICATOR_THREATS=false
TI_API__EXTRA_SETTINGS__IGNORE_NON_MALWARE_DDOS=true
TI_API__EXTRA_SETTINGS__INTRUSION_SET_INSTEAD_OF_THREAT_ACTOR=false
TI_API__EXTRA_SETTINGS__TIME_OUTPUT_FORMAT='%Y-%m-%d %H:%M:%S'
TI_API__EXTRA_SETTINGS__ENABLE_STATEMENT_MARKING=false
# When true, the connector omits x_opencti_labels from STIX bundles so the OpenCTI
# worker's update path does not overwrite labels that were added manually by
# analysts. Trade-off: connector-supplied labels also stop being (re)applied.
TI_API__EXTRA_SETTINGS__PRESERVE_MANUAL_LABELS=false

# Development only: write logs to rotating files (connector.log inside LOG_FILE_DIR)
# Not intended for production use. Ensure the directory is mounted as a volume in docker-compose.yml
TI_API__EXTRA_SETTINGS__ENABLE_FILE_LOGGING=false
TI_API__EXTRA_SETTINGS__LOG_FILE_DIR=/opt/connector/logs
TI_API__EXTRA_SETTINGS__LOG_FILE_MAX_BYTES=10485760
TI_API__EXTRA_SETTINGS__LOG_FILE_BACKUP_COUNT=5

# === Collections ===
# DEFAULT_DATE — initial lookback for the FIRST run only (YYYY-MM-DD). After the first
# run, the sequpdate cursor from the API takes over and DEFAULT_DATE is ignored.
# Strongly recommended for every collection you ENABLE: fill in an explicit date —
# see README section "Recommended DEFAULT_DATE per collection" for the suggested
# lookback per collection. If left empty, the API adapter falls back to today
# minus 3 days for the initial seqUpdate lookup.

TI_API__COLLECTIONS__APT_THREAT__DEFAULT_DATE=
TI_API__COLLECTIONS__APT_THREAT__ENABLE=false
TI_API__COLLECTIONS__APT_THREAT__LOCAL_CUSTOM_TAG=null
TI_API__COLLECTIONS__APT_THREAT__TTL=1460
TI_API__COLLECTIONS__APT_THREAT__USE_HUNTING_RULES=false
TI_API__COLLECTIONS__APT_THREAT__STORE_REPORT_LABELS_IN_NOTE=false
TI_API__COLLECTIONS__APT_THREAT__ADD_THREAT_ACTOR_LABEL_TO_OBSERVABLES=true
TI_API__COLLECTIONS__APT_THREAT__INCLUDE_THREAT_ACTOR_LABELS=true
TI_API__COLLECTIONS__APT_THREAT__INCLUDE_NATION_STATE_LABEL=true
TI_API__COLLECTIONS__APT_THREAT__INCLUDE_CONTEXT_LABEL=true
TI_API__COLLECTIONS__APT_THREAT__DESCRIPTION_IN_EXTERNAL_REFERENCES=false
# Promote report victimology into searchable SDOs: sectors -> Identity (Sector),
# targetedCompany / targetedPartnersAndClients -> Identity (Organization),
# regions -> Location (Region); linked as "<actor> targets <entity>" when the
# report carries a threat actor.
TI_API__COLLECTIONS__APT_THREAT__TARGETED_ENTITIES_AS_SDO=true
# Add expertise labels (bare values) from the report "expertise" field.
TI_API__COLLECTIONS__APT_THREAT__INCLUDE_EXPERTISE_LABELS=true

TI_API__COLLECTIONS__APT_THREAT_ACTOR__DEFAULT_DATE=
TI_API__COLLECTIONS__APT_THREAT_ACTOR__ENABLE=false
TI_API__COLLECTIONS__APT_THREAT_ACTOR__LOCAL_CUSTOM_TAG=null
TI_API__COLLECTIONS__APT_THREAT_ACTOR__TTL=1460
TI_API__COLLECTIONS__APT_THREAT_ACTOR__USE_HUNTING_RULES=false
TI_API__COLLECTIONS__APT_THREAT_ACTOR__INCLUDE_NATION_STATE_LABEL=true
TI_API__COLLECTIONS__APT_THREAT_ACTOR__DESCRIPTION_IN_EXTERNAL_REFERENCES=false

TI_API__COLLECTIONS__ATTACKS_DDOS__DEFAULT_DATE=
TI_API__COLLECTIONS__ATTACKS_DDOS__ENABLE=false
TI_API__COLLECTIONS__ATTACKS_DDOS__LOCAL_CUSTOM_TAG=null
TI_API__COLLECTIONS__ATTACKS_DDOS__TTL=10
TI_API__COLLECTIONS__ATTACKS_DDOS__USE_HUNTING_RULES=false
# CnC (attacker) domain/url/ip become Indicators; target stays a plain observable.
TI_API__COLLECTIONS__ATTACKS_DDOS__CNC_AS_INDICATOR=true
# Create an Incident SDO per DDoS attack (linked to observables/malware/actor).
TI_API__COLLECTIONS__ATTACKS_DDOS__CREATE_INCIDENT=true

TI_API__COLLECTIONS__ATTACKS_DEFACE__DEFAULT_DATE=
TI_API__COLLECTIONS__ATTACKS_DEFACE__ENABLE=false
TI_API__COLLECTIONS__ATTACKS_DEFACE__LOCAL_CUSTOM_TAG=null
TI_API__COLLECTIONS__ATTACKS_DEFACE__TTL=10
# Create an Incident SDO per defacement (linked to observables/actor/location).
TI_API__COLLECTIONS__ATTACKS_DEFACE__CREATE_INCIDENT=true

TI_API__COLLECTIONS__ATTACKS_PHISHING_GROUP__DEFAULT_DATE=
TI_API__COLLECTIONS__ATTACKS_PHISHING_GROUP__ENABLE=false
TI_API__COLLECTIONS__ATTACKS_PHISHING_GROUP__LOCAL_CUSTOM_TAG=null
TI_API__COLLECTIONS__ATTACKS_PHISHING_GROUP__TTL=5
TI_API__COLLECTIONS__ATTACKS_PHISHING_GROUP__USE_HUNTING_RULES=false
# Impersonated brand -> Identity (Organization) linked to the phishing observables.
TI_API__COLLECTIONS__ATTACKS_PHISHING_GROUP__BRAND_AS_IDENTITY=true
# Add brand labels (bare brand names) to all emitted entities of the event.
TI_API__COLLECTIONS__ATTACKS_PHISHING_GROUP__INCLUDE_BRAND_LABELS=true

TI_API__COLLECTIONS__ATTACKS_PHISHING_KIT__DEFAULT_DATE=
TI_API__COLLECTIONS__ATTACKS_PHISHING_KIT__ENABLE=false
TI_API__COLLECTIONS__ATTACKS_PHISHING_KIT__LOCAL_CUSTOM_TAG=null
TI_API__COLLECTIONS__ATTACKS_PHISHING_KIT__TTL=30
TI_API__COLLECTIONS__ATTACKS_PHISHING_KIT__USE_HUNTING_RULES=false
# targetBrand values -> Identity (Organization) linked to the kit observables.
TI_API__COLLECTIONS__ATTACKS_PHISHING_KIT__BRAND_AS_IDENTITY=true
TI_API__COLLECTIONS__ATTACKS_PHISHING_KIT__INCLUDE_BRAND_LABELS=true

TI_API__COLLECTIONS__COMPROMISED_ACCESS__DEFAULT_DATE=
TI_API__COLLECTIONS__COMPROMISED_ACCESS__ENABLE=false
TI_API__COLLECTIONS__COMPROMISED_ACCESS__LOCAL_CUSTOM_TAG=null
TI_API__COLLECTIONS__COMPROMISED_ACCESS__TTL=1460
# Raw data block in note: max chars for preview (default 2000); if full_data=true, no truncation
TI_API__COLLECTIONS__COMPROMISED_ACCESS__DATA_PREVIEW_MAX_LEN=2000
TI_API__COLLECTIONS__COMPROMISED_ACCESS__FULL_DATA=false
TI_API__COLLECTIONS__COMPROMISED_ACCESS__DESCRIPTION_IN_EXTERNAL_REFERENCES=false
# CnC (marketplace) domain/url/ip become Indicators (valid_from = compromise date, + TTL).
TI_API__COLLECTIONS__COMPROMISED_ACCESS__CNC_AS_INDICATOR=true
# Emit target.host/domain/ip as plain observables so customers can search their assets.
TI_API__COLLECTIONS__COMPROMISED_ACCESS__TARGET_OBSERVABLES=true

TI_API__COLLECTIONS__COMPROMISED_ACCOUNT_GROUP__DEFAULT_DATE=
TI_API__COLLECTIONS__COMPROMISED_ACCOUNT_GROUP__ENABLE=false
TI_API__COLLECTIONS__COMPROMISED_ACCOUNT_GROUP__LOCAL_CUSTOM_TAG=null
TI_API__COLLECTIONS__COMPROMISED_ACCOUNT_GROUP__TTL=1460
# Compromised account group: connector behavior
TI_API__COLLECTIONS__COMPROMISED_ACCOUNT_GROUP__INCLUDE_PASSWORDS=false
TI_API__COLLECTIONS__COMPROMISED_ACCOUNT_GROUP__INCLUDE_MALWARE_LABELS=true
TI_API__COLLECTIONS__COMPROMISED_ACCOUNT_GROUP__INCLUDE_MALWARE_THREAT_ACTOR_LABELS=true
# If true, add labels from API field "source_type" (e.g. leak type) to observables/entities as bare values
TI_API__COLLECTIONS__COMPROMISED_ACCOUNT_GROUP__INCLUDE_SOURCE_TYPE_LABELS=true
TI_API__COLLECTIONS__COMPROMISED_ACCOUNT_GROUP__DESCRIPTION_IN_EXTERNAL_REFERENCES=false
# Compromised account group: API request params
TI_API__COLLECTIONS__COMPROMISED_ACCOUNT_GROUP__UNIQUE=0
TI_API__COLLECTIONS__COMPROMISED_ACCOUNT_GROUP__COMBOLIST=0
TI_API__COLLECTIONS__COMPROMISED_ACCOUNT_GROUP__PROBABLE_CORPORATE_ACCESS=0

