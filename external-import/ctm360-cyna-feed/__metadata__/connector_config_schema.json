{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.filigran.io/connectors/ctm360-cyna-feed_config.schema.json",
  "type": "object",
  "properties": {
    "OPENCTI_URL": {
      "description": "The base URL of the OpenCTI instance.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string"
    },
    "OPENCTI_TOKEN": {
      "description": "The API token to connect to OpenCTI.",
      "type": "string"
    },
    "CONNECTOR_NAME": {
      "default": "CTM360-CYNA",
      "type": "string"
    },
    "CONNECTOR_SCOPE": {
      "description": "The scope of the connector, e.g. 'flashpoint'.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "CONNECTOR_LOG_LEVEL": {
      "default": "error",
      "description": "The minimum level of logs to display.",
      "enum": [
        "debug",
        "info",
        "warn",
        "warning",
        "error"
      ],
      "type": "string"
    },
    "CONNECTOR_TYPE": {
      "const": "EXTERNAL_IMPORT",
      "default": "EXTERNAL_IMPORT",
      "type": "string"
    },
    "CONNECTOR_DURATION_PERIOD": {
      "description": "The period of time to await between two runs of the connector.",
      "format": "duration",
      "type": "string"
    },
    "CTM360_CYNA_API_BASE_URL": {
      "default": "https://cyna.ctm360.com",
      "description": "CYNA API base URL.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string"
    },
    "CTM360_CYNA_API_KEY": {
      "description": "API key for CYNA authentication.",
      "format": "password",
      "type": "string",
      "writeOnly": true
    },
    "CTM360_CYNA_IMPORT_INTERVAL": {
      "default": 86400,
      "description": "Interval in seconds between imports (default: 24h).",
      "exclusiveMinimum": 0,
      "type": "integer"
    },
    "CTM360_CYNA_PAGE_SIZE": {
      "default": 25,
      "description": "Number of news items per API page (default: 25).",
      "exclusiveMinimum": 0,
      "type": "integer"
    },
    "CTM360_CYNA_MAX_PAGES": {
      "default": 100,
      "description": "Maximum pages to fetch per import cycle (safety limit).",
      "exclusiveMinimum": 0,
      "type": "integer"
    }
  },
  "required": [
    "OPENCTI_URL",
    "OPENCTI_TOKEN",
    "CONNECTOR_SCOPE",
    "CONNECTOR_DURATION_PERIOD",
    "CTM360_CYNA_API_KEY"
  ],
  "additionalProperties": true
}