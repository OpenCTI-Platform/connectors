{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.filigran.io/connectors/hunt-io_config.schema.json",
  "type": "object",
  "properties": {
    "OPENCTI_URL": {
      "description": "The base URL of the OpenCTI instance.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string"
    },
    "OPENCTI_TOKEN": {
      "description": "The API token to connect to OpenCTI.",
      "type": "string"
    },
    "CONNECTOR_NAME": {
      "default": "Hunt IO",
      "description": "Display name for this connector instance in the OpenCTI platform",
      "type": "string"
    },
    "CONNECTOR_SCOPE": {
      "default": [
        "Hunt IO"
      ],
      "description": "Entity types or categories this connector will handle. Used for filtering and organization within OpenCTI",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "CONNECTOR_LOG_LEVEL": {
      "default": "error",
      "description": "The minimum level of logs to display.",
      "enum": [
        "debug",
        "info",
        "warn",
        "warning",
        "error"
      ],
      "type": "string"
    },
    "CONNECTOR_TYPE": {
      "const": "EXTERNAL_IMPORT",
      "default": "EXTERNAL_IMPORT",
      "type": "string"
    },
    "CONNECTOR_DURATION_PERIOD": {
      "default": "P1D",
      "description": "Time interval between consecutive data imports from Hunt.io. Controls how frequently the connector runs",
      "format": "duration",
      "type": "string"
    },
    "CONNECTOR_HUNT_UI_API_BASE_URL": {
      "default": "https://api.hunt.io/v1/feeds/c2",
      "description": "Use HUNT_IO_API_BASE_URL instead.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string",
      "deprecated": true
    },
    "CONNECTOR_HUNT_UI_API_KEY": {
      "description": "Use HUNT_IO_API_KEY instead.",
      "format": "password",
      "type": "string",
      "writeOnly": true,
      "deprecated": true
    },
    "CONNECTOR_HUNT_UI_TLP_LEVEL": {
      "default": "amber",
      "description": "Use HUNT_IO_TLP_LEVEL instead.",
      "enum": [
        "white",
        "clear",
        "green",
        "amber",
        "amber+strict",
        "red"
      ],
      "type": "string",
      "deprecated": true
    },
    "CONNECTOR_HUNT_IO_API_BASE_URL": {
      "default": "https://api.hunt.io/v1/feeds/c2",
      "description": "Use HUNT_IO_API_BASE_URL instead.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string",
      "deprecated": true
    },
    "CONNECTOR_HUNT_IO_API_KEY": {
      "description": "Use HUNT_IO_API_KEY instead.",
      "format": "password",
      "type": "string",
      "writeOnly": true,
      "deprecated": true
    },
    "CONNECTOR_HUNT_IO_TLP_LEVEL": {
      "default": "amber",
      "description": "Use HUNT_IO_TLP_LEVEL instead.",
      "enum": [
        "white",
        "clear",
        "green",
        "amber",
        "amber+strict",
        "red"
      ],
      "type": "string",
      "deprecated": true
    },
    "HUNT_IO_API_BASE_URL": {
      "default": "https://api.hunt.io/v1/feeds/c2",
      "description": "Hunt.io API endpoint URL for the C2 threat intelligence feeds",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string"
    },
    "HUNT_IO_API_KEY": {
      "description": "Authentication key for accessing the Hunt.io API. Obtain this from your Hunt.io account settings",
      "format": "password",
      "type": "string",
      "writeOnly": true
    },
    "HUNT_IO_TLP_LEVEL": {
      "default": "amber",
      "description": "Traffic Light Protocol (TLP) marking level to apply to imported data, controlling information sharing restrictions",
      "enum": [
        "white",
        "clear",
        "green",
        "amber",
        "amber+strict",
        "red"
      ],
      "type": "string"
    }
  },
  "required": [
    "OPENCTI_URL",
    "OPENCTI_TOKEN",
    "HUNT_IO_API_KEY"
  ],
  "additionalProperties": true
}