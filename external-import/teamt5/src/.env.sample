#OpenCTI Configuration
OPENCTI_URL=http://opencti:8080
OPENCTI_TOKEN=ChangeMe

#Common Connector Configuration
CONNECTOR_ID=ChangeMe
CONNECTOR_NAME='Team T5 External Import Connector'
CONNECTOR_SCOPE=teamt5
CONNECTOR_LOG_LEVEL=error
CONNECTOR_DURATION_PERIOD=P1D

#Connector Configuration

# TeamT5 API host. Defaults to the public ThreatVision endpoint.
# Override for private / on-prem TeamT5 deployments.
TEAMT5_API_BASE_URL=https://api.threatvision.org

# OAuth 2.0 client credentials (RECOMMENDED).
# When both OAuth fields are set, OAuth takes precedence over the
# legacy API key. The connector exchanges these for a short-lived
# Bearer token against `${TEAMT5_API_BASE_URL}/oauth/token` and
# refreshes 60 s before expiry.
TEAMT5_CLIENT_ID=ChangeMe
TEAMT5_CLIENT_SECRET=ChangeMe

# Legacy static API key (DEPRECATED, OAuth is preferred).
# Leave unset when `TEAMT5_CLIENT_ID` / `TEAMT5_CLIENT_SECRET` are
# configured; only set this on tenants that have not yet been migrated
# to OAuth 2.0 client credentials. The Pydantic settings validator
# requires *either* the OAuth pair *or* this key to be configured at
# startup.
# TEAMT5_API_KEY=ChangeMe

TEAMT5_TLP_LEVEL=clear
# Optional. Unix timestamp of the earliest intel to pull on the first run.
# Defaults to 0 (full TeamT5 catalogue) when unset.
TEAMT5_FIRST_RUN_RETRIEVAL_TIMESTAMP=0
