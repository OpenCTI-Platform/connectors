{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.filigran.io/connectors/ctm360-hackerview-feed_config.schema.json",
  "type": "object",
  "properties": {
    "OPENCTI_URL": {
      "description": "The base URL of the OpenCTI instance.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string"
    },
    "OPENCTI_TOKEN": {
      "description": "The API token to connect to OpenCTI.",
      "type": "string"
    },
    "CONNECTOR_NAME": {
      "default": "CTM360-HackerView",
      "type": "string"
    },
    "CONNECTOR_SCOPE": {
      "description": "The scope of the connector, e.g. 'flashpoint'.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "CONNECTOR_LOG_LEVEL": {
      "default": "error",
      "description": "The minimum level of logs to display.",
      "enum": [
        "debug",
        "info",
        "warn",
        "warning",
        "error"
      ],
      "type": "string"
    },
    "CONNECTOR_TYPE": {
      "const": "EXTERNAL_IMPORT",
      "default": "EXTERNAL_IMPORT",
      "type": "string"
    },
    "CONNECTOR_DURATION_PERIOD": {
      "description": "The period of time to await between two runs of the connector.",
      "format": "duration",
      "type": "string"
    },
    "CTM360_HV_API_BASE_URL": {
      "default": "https://hackerview.ctm360.com",
      "description": "HackerView API base URL.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string"
    },
    "CTM360_HV_API_KEY": {
      "description": "API key for HackerView authentication.",
      "type": "string"
    },
    "CTM360_HV_IMPORT_INTERVAL": {
      "default": 86400,
      "description": "Interval in seconds between imports (default: 24h).",
      "type": "integer"
    },
    "CTM360_HV_IMPORT_ISSUES": {
      "default": true,
      "description": "Enable importing security issues.",
      "type": "boolean"
    },
    "CTM360_HV_IMPORT_RESOLVED_ISSUES": {
      "default": true,
      "description": "Enable importing resolved issues.",
      "type": "boolean"
    },
    "CTM360_HV_IMPORT_DOMAIN_ASSETS": {
      "default": true,
      "description": "Enable importing domain assets.",
      "type": "boolean"
    },
    "CTM360_HV_IMPORT_HOST_ASSETS": {
      "default": true,
      "description": "Enable importing hostname assets.",
      "type": "boolean"
    },
    "CTM360_HV_IMPORT_IP_ASSETS": {
      "default": true,
      "description": "Enable importing IP address assets.",
      "type": "boolean"
    },
    "CTM360_HV_STATUS_POLL_INTERVAL": {
      "default": 3600,
      "description": "Interval in seconds between status polling cycles (default: 1h).",
      "type": "integer"
    },
    "CTM360_HV_ENABLE_STATUS_TRACKING": {
      "default": true,
      "description": "Enable background polling for issue status changes.",
      "type": "boolean"
    }
  },
  "required": [
    "OPENCTI_URL",
    "OPENCTI_TOKEN",
    "CONNECTOR_SCOPE",
    "CONNECTOR_DURATION_PERIOD",
    "CTM360_HV_API_KEY"
  ],
  "additionalProperties": true
}