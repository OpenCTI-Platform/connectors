{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.filigran.io/connectors/sigmahq_config.schema.json",
  "type": "object",
  "properties": {
    "OPENCTI_URL": {
      "description": "The base URL of the OpenCTI instance.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string"
    },
    "OPENCTI_TOKEN": {
      "description": "The API token to connect to OpenCTI.",
      "type": "string"
    },
    "CONNECTOR_NAME": {
      "default": "SigmaHQ",
      "description": "The name of the connector.",
      "type": "string"
    },
    "CONNECTOR_SCOPE": {
      "default": [
        "sigmahq"
      ],
      "description": "The scope of the connector",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "CONNECTOR_LOG_LEVEL": {
      "default": "error",
      "description": "The minimum level of logs to display.",
      "enum": [
        "debug",
        "info",
        "warn",
        "warning",
        "error"
      ],
      "type": "string"
    },
    "CONNECTOR_TYPE": {
      "const": "EXTERNAL_IMPORT",
      "default": "EXTERNAL_IMPORT",
      "type": "string"
    },
    "CONNECTOR_DURATION_PERIOD": {
      "default": "P1D",
      "description": "The period of time to await between two runs of the connector. (Default: 1 day)",
      "format": "duration",
      "type": "string"
    },
    "SIGMAHQ_RULE_PACKAGE": {
      "default": "sigma_all_rules",
      "description": "Rule package to import",
      "enum": [
        "sigma_all_rules",
        "sigma_core++",
        "sigma_core+",
        "sigma_core",
        "sigma_emerging_threats_addon"
      ],
      "type": "string"
    },
    "SIGMAHQ_TLP_LEVEL": {
      "default": "clear",
      "description": "Default TLP level of the imported entities.",
      "enum": [
        "clear",
        "white",
        "green",
        "amber",
        "amber+strict",
        "red"
      ],
      "type": "string"
    }
  },
  "required": [
    "OPENCTI_URL",
    "OPENCTI_TOKEN"
  ],
  "additionalProperties": true
}