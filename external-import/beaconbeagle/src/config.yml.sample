opencti:
  url: 'http://localhost:8080'
  token: 'ChangeMe'


connector:
  id: 'ChangeMe'
  type: 'EXTERNAL_IMPORT'
  name: 'BeaconBeagle'
  scope: 'beaconbeagle'
  log_level: 'info'


beaconbeagle:
  url: 'https://beaconbeagle.com/api/v1/c2?q=&protocol=&port=&min_endpoints=0&first_after=&first_before=&last_after=&last_before=&sort=firsttime&order=desc'
  # Boolean fields must be real YAML booleans (``true`` / ``false`` without
  # quotes). Quoted ``'true'`` / ``'false'`` are YAML *strings*, and Python's
  # truthiness rules treat any non-empty string as ``True`` — so a
  # quoted ``'false'`` would silently enable the feature.
  add_urls: true
  add_useragent: true
  link_tool: 'CobaltStrike'
  link_ap: 'T1071 Standard Application Layer Protocol'
  link_country: true
  link_bgpas: true
  # When true, the connector falls back to a ``whois -h bgp.tools -v <ip>``
  # lookup whenever the BeaconBeagle payload itself does not carry an
  # ``asn`` / ``country`` for a C2 entry. Disable if outbound traffic
  # to ``bgp.tools`` is not allowed in your deployment (BGP / AS / country
  # linking will then only fire on entries that already carry the data).
  search_bgpas: false
  # Suffix appended to the Text observable that tracks CobaltStrike licence
  # watermarks. Leave empty (or omit) to disable watermark tracking.
  link_watermark: ''
  links_duration: 24
  interval: 2 # In hours
  marking_definition: 'TLP:GREEN'