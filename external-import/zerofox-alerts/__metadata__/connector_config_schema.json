{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://www.filigran.io/connectors/zerofox-alerts_config.schema.json",
  "type": "object",
  "properties": {
    "OPENCTI_URL": {
      "description": "The base URL of the OpenCTI instance.",
      "format": "uri",
      "maxLength": 2083,
      "minLength": 1,
      "type": "string"
    },
    "OPENCTI_TOKEN": {
      "description": "The API token to connect to OpenCTI.",
      "type": "string"
    },
    "CONNECTOR_NAME": {
      "default": "ZeroFox Alerts",
      "description": "The name of the connector.",
      "type": "string"
    },
    "CONNECTOR_SCOPE": {
      "default": [
        "zerofox-alerts"
      ],
      "description": "The scope of the connector.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "CONNECTOR_LOG_LEVEL": {
      "default": "error",
      "description": "The minimum level of logs to display.",
      "enum": [
        "debug",
        "info",
        "warn",
        "warning",
        "error"
      ],
      "type": "string"
    },
    "CONNECTOR_TYPE": {
      "const": "EXTERNAL_IMPORT",
      "default": "EXTERNAL_IMPORT",
      "type": "string"
    },
    "CONNECTOR_DURATION_PERIOD": {
      "default": "PT15M",
      "description": "The period of time to await between two runs of the connector.",
      "format": "duration",
      "type": "string"
    },
    "ZEROFOX_ALERTS_API_BASE_URL": {
      "default": "https://api.zerofox.com",
      "description": "Base URL of the ZeroFox API.",
      "type": "string"
    },
    "ZEROFOX_ALERTS_API_TOKEN": {
      "description": "ZeroFox Personal Access Token (PAT) for authentication.",
      "format": "password",
      "type": "string",
      "writeOnly": true
    },
    "ZEROFOX_ALERTS_MARKING": {
      "default": "TLP:AMBER",
      "description": "TLP marking definition to apply to created objects.",
      "enum": [
        "TLP:CLEAR",
        "TLP:WHITE",
        "TLP:GREEN",
        "TLP:AMBER",
        "TLP:AMBER+STRICT",
        "TLP:RED"
      ],
      "type": "string"
    },
    "ZEROFOX_ALERTS_IMPORT_START_DATE": {
      "default": "P30D",
      "description": "How far back to look on the first import (e.g. 'P30D' for 30 days, 'P6M' for 6 months).",
      "format": "duration",
      "type": "string"
    },
    "ZEROFOX_ALERTS_ALERT_STATUSES": {
      "default": [
        "open",
        "escalated",
        "investigation_completed"
      ],
      "description": "Alert statuses to import (comma-separated). E.g. 'open,escalated,investigation_completed'.",
      "items": {
        "type": "string"
      },
      "type": "array"
    },
    "ZEROFOX_ALERTS_PAGE_SIZE": {
      "default": 100,
      "description": "Number of alerts to retrieve per API page.",
      "maximum": 100,
      "minimum": 1,
      "type": "integer"
    }
  },
  "required": [
    "OPENCTI_URL",
    "OPENCTI_TOKEN",
    "ZEROFOX_ALERTS_API_TOKEN"
  ],
  "additionalProperties": true
}