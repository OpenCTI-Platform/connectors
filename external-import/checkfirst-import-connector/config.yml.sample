opencti:
  url: http://localhost
  token: CHANGEME

connector:
  id: CHANGEME
  name: Checkfirst Import Connector
  scope: checkfirst
  log_level: info
  duration_period: P7D

checkfirst:
  api_url: ChangeMe
  api_key: ChangeMe
  api_endpoint: /v1/articles
  since: P365D
  force_reprocess: false
  tlp_level: clear
  # Entity-type ingestion filters (default: true — all entity types are ingested).
  # Set any of these to false to exclude that entity type and all its downstream
  # relationships from per-article bundles, reducing OpenCTI stream pressure.
  import_domain_name: true
  import_infrastructure: true
  import_channel: true
  import_source_channel: true
  import_media_content: true
