# Sample env file for local runs (host or container)
# Copy to `.env` and replace the ChangeMe values.
#
# Note: `connectors_sdk` will automatically load `.env` when the connector starts.
# If you already have system env vars like OPENCTI_TOKEN set, they will override `.env`.
# To force `.env` values when launching, use python-dotenv with override:
#   dotenv -f .env -o run -- python -u src\main.py

# OpenCTI configuration
OPENCTI_URL=http://localhost
OPENCTI_TOKEN=ChangeMe

# Connector common configuration
CONNECTOR_ID=ChangeMe
CONNECTOR_NAME=Checkfirst Import Connector
CONNECTOR_SCOPE=checkfirst
CONNECTOR_LOG_LEVEL=info

# Connector specific configuration
CHECKFIRST_API_URL=ChangeMe
CHECKFIRST_API_KEY=ChangeMe
CHECKFIRST_API_ENDPOINT=/v1/articles
CHECKFIRST_SINCE=P365D
CHECKFIRST_TLP_LEVEL=clear
CHECKFIRST_IMPORT_DOMAIN_NAME=true
CHECKFIRST_IMPORT_INFRASTRUCTURE=true
CHECKFIRST_IMPORT_CHANNEL=true
CHECKFIRST_IMPORT_SOURCE_CHANNEL=true
CHECKFIRST_IMPORT_MEDIA_CONTENT=true
