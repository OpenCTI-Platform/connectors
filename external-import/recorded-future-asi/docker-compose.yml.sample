version: '3'
services:
  connector-recorded-future-asi:
    image: opencti/connector-recorded-future-asi:latest # 'recorded-future-asi' being the name of connector's directory
    environment:
      # Generic parameters (connection with OpenCTI)
      - OPENCTI_URL=http://localhost
      - OPENCTI_TOKEN=CHANGEME
      # Common parameters for connectors of type EXTERNAL_IMPORT
      - CONNECTOR_ID=CHANGEME
      - CONNECTOR_NAME=Recorded Future ASI Exposures # optional (default: 'Recorded Future ASI Exposures')
      - CONNECTOR_SCOPE=incident,vulnerability,ipv4-addr,ipv6-addr,domain-name # optional (default: 'incident,vulnerability,ipv4-addr,ipv6-addr,domain-name')
      - CONNECTOR_LOG_LEVEL=error # optional (default: 'error')
      - CONNECTOR_DURATION_PERIOD=PT1H # optional, interval in ISO-8601 format between two runs of the connector (default: 'PT1H')
      # Custom parameters for connector-recorded-future-asi
      - RECORDED_FUTURE_ASI_API_BASE_URL=https://api.securitytrails.com/v2 # optional (default: 'https://api.securitytrails.com/v2')
      #- RF_HISTORY_API_BASE_URL=https://api.securitytrails.com/v1 #optional (default: 'https://api.securitytrails.com/v1')
      - RECORDED_FUTURE_ASI_API_KEY=CHANGEME
      - RECORDED_FUTURE_ASI_PROJECT_ID=CHANGEME
      - RECORDED_FUTURE_ASI_TLP_LEVEL=amber+strict # optional, available values: 'clear', 'white', 'green', 'amber', 'amber+strict', 'red' (default: 'amber+strict')
      - RECORDED_FUTURE_ASI_PAGE_LIMIT=100 # optional, API page size (HTTP request chunk), min 1, max 1000 (default: 100)
      # - RECORDED_FUTURE_ASI_RUN_LIMIT=50 # optional, max exposures processed per connector run, min 1 (default: no limit)
      # - RECORDED_FUTURE_ASI_RETRY_MAX_ATTEMPTS=3 # optional, max HTTP attempts per request, min 1, max 10 (default: 3)
      # - RECORDED_FUTURE_ASI_RETRY_INITIAL_SECONDS=1 # optional, initial retry backoff in seconds, min 0.1, max 30 (default: 1)
      # - RECORDED_FUTURE_ASI_RETRY_MAX_SECONDS=60 # optional, max retry backoff in seconds, min 1, max 300 (default: 60)
      # - RECORDED_FUTURE_ASI_FILTER_SEVERITY_MIN=moderate # optional, import exposures at or above this severity; values: unknown, informational, moderate, critical (mutually exclusive with RECORDED_FUTURE_ASI_FILTER_SEVERITY_EXACT)
      # - RECORDED_FUTURE_ASI_FILTER_SEVERITY_EXACT=critical # optional, import exposures matching this severity exactly; same values (mutually exclusive with RECORDED_FUTURE_ASI_FILTER_SEVERITY_MIN)
    restart: always
